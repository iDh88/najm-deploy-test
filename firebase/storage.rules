rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── Helper functions ────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isValidExcelFile() {
      return request.resource.contentType == 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
        || request.resource.contentType == 'application/vnd.ms-excel';
    }

    function isUnderSizeLimit() {
      // 10 MB limit for Excel uploads
      return request.resource.size <= 10 * 1024 * 1024;
    }

    // ─── User Roster Files ────────────────────────────────────────────────────
    // Path: users/{userId}/rosters/{fileName}
    match /users/{userId}/rosters/{fileName} {
      // Read: only the file owner or admin
      allow read: if isOwner(userId) || isAdmin();

      // Write: owner only, must be Excel, must be under size limit
      allow create, update: if isOwner(userId)
        && isValidExcelFile()
        && isUnderSizeLimit();

      // Delete: owner or admin
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ─── User Exports ─────────────────────────────────────────────────────────
    // Path: users/{userId}/exports/{fileName}
    // Generated by server-side functions (PDF exports, data archives)
    match /users/{userId}/exports/{fileName} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin(); // Only server-side writes
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ─── App Assets (read-only for authenticated users) ───────────────────────
    // Path: public/{fileName}
    match /public/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Layover Recommendation Photos ────────────────────────────────────────
    // Path: recommendations/{fileName}
    // Written by the Flutter app (layover_service.dart) when a crew member
    // submits a recommendation. F15: previously fell through to deny-all,
    // which broke photo uploads entirely.
    function isValidImage() {
      return request.resource.contentType == 'image/jpeg'
        || request.resource.contentType == 'image/png';
    }

    match /recommendations/{fileName} {
      // Photos are shown to any signed-in crew member browsing a city hub.
      allow read: if isAuthenticated();

      // Create only (immutable once uploaded): any approved authenticated
      // user, image type, 5 MB cap. No update — replacing another user's
      // photo is not a supported flow.
      allow create: if isAuthenticated()
        && isValidImage()
        && request.resource.size <= 5 * 1024 * 1024;

      // Moderation cleanup is admin-only.
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ─── Deny everything else ─────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
