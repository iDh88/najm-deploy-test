# ─── NAJM (Crew Intelligence Platform) — Environment Template ────────────────
# Copy to .env and fill in values.  NEVER commit .env (it is git-ignored).
#
# SECRETS below are PLACEHOLDERS only. In the cloud they are delivered by Google
# Secret Manager (see docs/SECRETS.md); locally they live in your .env.
# The Flutter and Admin clients receive NONE of these — they are server-side only.

# ══════════════════════════════════════════════════════════════════════════
#  SECRETS   cloud → Secret Manager   ·   local → this .env   ·   never client
# ══════════════════════════════════════════════════════════════════════════
# Service-to-service token (Cloud Functions → Python). Random 32+ char string.
#   Secret Manager id: internal-service-token
INTERNAL_SERVICE_TOKEN=change-me-in-production
# Anthropic (Claude) — assistant, filter generation, explanations.
#   Secret Manager id: anthropic-api-key
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI — knowledge-base embeddings (python_services/knowledge_engine). Required
# for knowledge-base features; leave blank to disable them.
#   Secret Manager id: openai-api-key
OPENAI_API_KEY=sk-...
# One-time admin bootstrap token (scripts/setup_super_admin.sh).
#   Secret Manager id: admin-setup-token
ADMIN_SETUP_TOKEN=REPLACE_WITH_RANDOM_SECRET_STRING

# ══════════════════════════════════════════════════════════════════════════
#  LOCAL-ONLY   (cloud uses the Cloud Run runtime service account / ADC)
# ══════════════════════════════════════════════════════════════════════════
# Path to a Firebase service-account key file for LOCAL development ONLY.
# Do NOT set this in the cloud — Cloud Run authenticates via Application Default
# Credentials (its attached service account). Local emulators need no key at all.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# ══════════════════════════════════════════════════════════════════════════
#  FIREBASE / GCP   (config — per environment; see ADR-001)
# ══════════════════════════════════════════════════════════════════════════
# dev: cip-najm-dev · staging: cip-najm-staging · prod: cip-najm
FIREBASE_PROJECT_ID=cip-najm
FIREBASE_STORAGE_BUCKET=cip-najm.appspot.com
GCP_PROJECT=cip-najm
GCP_REGION=me-central1
BIGQUERY_DATASET=cip

# ══════════════════════════════════════════════════════════════════════════
#  PYTHON SERVICE   (config)
# ══════════════════════════════════════════════════════════════════════════
ENV=development                                # development | production
PORT=8080                                      # Cloud Run listens on 8080 (start.sh uses 8000 locally)
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost,https://cip-najm.web.app
PYTHON_SERVICE_URL=http://localhost:8080       # Cloud Run URL in production
LEGALITY_RULES_TTL_SECONDS=300                 # Firestore legalityRules cache TTL (seconds)

# ══════════════════════════════════════════════════════════════════════════
#  AI BEHAVIOR   (config)
# ══════════════════════════════════════════════════════════════════════════
CLAUDE_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.3
AI_DAILY_FREE_LIMIT=50                          # free-tier daily AI allowance
# Provider switch for the NLP assistant (python_services/ai/nlp_router.py):
#   anthropic (default) | glm
AI_PROVIDER=anthropic
# GLM provider (used only when AI_PROVIDER=glm; key is a SECRET — Secret Manager in cloud)
# GLM_API_KEY=
# GLM_BASE_URL=
# GLM_MODEL=

# ══════════════════════════════════════════════════════════════════════════
#  MONITORING   (config)
# ══════════════════════════════════════════════════════════════════════════
# SENTRY_DSN=https://...@sentry.io/...

# ══════════════════════════════════════════════════════════════════════════
#  SUBSCRIPTIONS & RATE LIMITS   (config — launch is FREE; subs built but OFF)
# ══════════════════════════════════════════════════════════════════════════
SUBSCRIPTIONS_ENABLED=false
FREE_AI_QUERIES_PER_DAY=50
PRO_AI_QUERIES_PER_DAY=99999
FREE_UPLOADS_PER_DAY=1
PRO_UPLOADS_PER_DAY=99999
# Future billing = Apple IAP + Google Play via RevenueCat (Stripe/HyperPay removed).
# REVENUECAT_PUBLIC_SDK_KEY=
# REVENUECAT_WEBHOOK_AUTH_HEADER=

# ══════════════════════════════════════════════════════════════════════════
#  ROSTER SYNC — CAE provider   (config; server-side, owner-gated — ADR-001)
# ══════════════════════════════════════════════════════════════════════════
# CAE enterprise integration stays OFF unless ALL of these are set (owner-gated).
# ZK_... is the owner's written approval reference, format: <owner>/<date>/<ADR>.
ZK_SERVER_ORCHESTRATION_OWNER_APPROVAL=
CAE_ENTERPRISE_BASE_URL=
CAE_OFFICIAL_DEVICE_CONFIG=

# ══════════════════════════════════════════════════════════════════════════
#  ADMIN
# ══════════════════════════════════════════════════════════════════════════
SUPER_ADMIN_EMAIL=NajmAssistance@gmail.com

# ══════════════════════════════════════════════════════════════════════════
#  FLUTTER / ADMIN CLIENT   (build-time only — NO secrets, ever)
# ══════════════════════════════════════════════════════════════════════════
# Client host is passed at BUILD time via --dart-define, not read from this file:
#   flutter run --dart-define=AI_SERVICE_URL=http://localhost:8000
# Firebase client config comes from firebase_options.dart (flutterfire configure),
# NOT from here. Firebase web API keys are public identifiers, not secrets.
