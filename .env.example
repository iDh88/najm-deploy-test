# ─── Crew Intelligence Platform — Environment Variables ──────────────────────
# Copy to .env and fill in values. NEVER commit .env to version control.

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=cip-najm
FIREBASE_STORAGE_BUCKET=cip-najm.appspot.com
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json  # local dev only

# ── Python Services ───────────────────────────────────────────────────────────
ENV=development                   # development | production
PORT=8080
ALLOWED_ORIGINS=http://localhost,https://cip-najm.web.app
INTERNAL_SERVICE_TOKEN=change-me-in-production
PYTHON_SERVICE_URL=http://localhost:8080   # Cloud Run URL in production

# ── Anthropic AI ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.3

# ── Rate Limits ───────────────────────────────────────────────────────────────
FREE_AI_QUERIES_PER_DAY=50
PRO_AI_QUERIES_PER_DAY=99999
FREE_UPLOADS_PER_DAY=1
PRO_UPLOADS_PER_DAY=99999

# ── Payments ──────────────────────────────────────────────────────────────────
# ─── Payments ─────────────────────────────────────────────────────────────────
# Launch is FREE; subscriptions are built but DISABLED. Toggle when ready:
SUBSCRIPTIONS_ENABLED=false
# AI free-tier daily allowance (used while subscriptions are disabled):
AI_DAILY_FREE_LIMIT=50
# Future billing = Apple IAP + Google Play Billing, synced via RevenueCat.
# Stripe and HyperPay are NOT in the roadmap (removed 0.3).
# REVENUECAT_PUBLIC_SDK_KEY=
# REVENUECAT_WEBHOOK_AUTH_HEADER=

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT=cip-najm
GCP_REGION=me-central1
BIGQUERY_DATASET=cip

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
LOG_LEVEL=INFO

# ── Flutter Build Vars (passed via --dart-define) ──────────────────────────
# flutter run --dart-define=AI_SERVICE_URL=http://localhost:8080
# flutter run --dart-define=IS_PRODUCTION=false

# ── Admin Configuration ──────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=NajmAssistance@gmail.com
ADMIN_SETUP_TOKEN=REPLACE_WITH_RANDOM_SECRET_STRING
